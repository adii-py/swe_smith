+#[cfg(test)]
+mod api_logs_regression_tests {
+    #[test]
+    fn test_timestamp_uses_division_not_multiplication() {
+        // Simulate the calculation done in ApiEvent::new
+        let now_nanos: i128 = 1_700_000_000_000_000_000i128;
+
+        // CORRECT: division produces milliseconds
+        let correct_millis = now_nanos / 1_000_000;
+
+        // BUGGY: multiplication produces astronomically large value
+        let buggy_millis = now_nanos * 1_000_000;
+
+        // Reasonable millisecond range for years 2017-2033
+        const MIN_MILLIS: i128 = 1_500_000_000_000i128;
+        const MAX_MILLIS: i128 = 2_000_000_000_000i128;
+
+        // This test documents the expected behavior
+        // With correct code (/): value is ~1.7 trillion (PASS)
+        // With buggy code (*): value is ~1.7 quintillion (FAIL)
+        assert!(
+            correct_millis >= MIN_MILLIS && correct_millis <= MAX_MILLIS,
+            "Timestamp should be in milliseconds (approx 1.7 trillion for year 2024), got {}",
+            correct_millis
+        );
+    }
+}
