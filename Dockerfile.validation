FROM swebench/swesmith.arm64.juspay_1776_hyperswitch.fece9bc3:latest

# Install pip, docker-cli and dependencies
RUN apt-get update && apt-get install -y python3-pip ca-certificates curl gnupg && \
    install -m 0755 -d /etc/apt/keyrings && \
    curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg && \
    chmod a+r /etc/apt/keyrings/docker.gpg && \
    echo "deb [arch="$(dpkg --print-architecture)" signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian \
    "$(. /etc/os-release && echo "$VERSION_CODENAME")" stable" > /etc/apt/sources.list.d/docker.list && \
    apt-get update && \
    apt-get install -y docker-ce-cli && \
    pip3 install --break-system-packages swebench unidiff tqdm python-dotenv rich ghapi

# Set working directory
WORKDIR /workspace

# Default command
CMD ["bash"]
