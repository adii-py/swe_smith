FROM swesmith-validation:latest

WORKDIR /testbed

# Enable redis-rs feature for compilation
RUN sed -i 's/storage_impl = { version = "0.1.0", path = "..\/storage_impl", default-features = false }/storage_impl = { version = "0.1.0", path = "..\/storage_impl", default-features = false, features = ["redis-rs"] }/' crates/analytics/Cargo.toml || true
RUN sed -i 's/redis_interface = { version = "0.1.0", path = "..\/redis_interface", default-features = false }/redis_interface = { version = "0.1.0", path = "..\/redis_interface", default-features = false, features = ["redis-rs"] }/' crates/storage_impl/Cargo.toml || true

WORKDIR /testbed
